{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev: All",
      "dependsOn": ["Dev: Server", "Dev: Web"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Dev: Server",
      "type": "shell",
      "command": "bun",
      "args": ["run", "dev:api"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Dev: Web",
      "type": "shell",
      "command": "bun",
      "args": ["run", "dev:web"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}

{
  "name": "lede",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch --env-file-if-exists=.env src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "start": "tsx --env-file-if-exists=.env src/server/index.ts",
    "test": "vitest run --passWithNoTests && playwright test && LEDE_E2E_DOCKER=1 playwright test --project=docker",
    "test:e2e": "playwright test",
    "test:docker": "LEDE_E2E_DOCKER=1 playwright test --project=docker",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.5",
    "@ai-sdk/google": "^4.0.6",
    "@ai-sdk/openai": "^4.0.5",
    "@fastify/secure-session": "7.5.1",
    "@fastify/static": "7.0.4",
    "@fontsource/arimo": "^5.2.8",
    "@fontsource/carlito": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.1.0",
    "@fontsource/ibm-plex-sans": "^5.1.0",
    "@fontsource/ibm-plex-serif": "^5.1.0",
    "@fontsource/tinos": "^5.2.7",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-query": "^5.62.7",
    "ai": "^7.0.11",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "0.8.3",
    "fastify": "^4.28.1",
    "lucide-react": "^0.469.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^6.28.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}

{
  "name": "lede",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun --watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "start": "bun src/server/index.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.5",
    "@ai-sdk/google": "^4.0.6",
    "@ai-sdk/openai": "^4.0.5",
    "ai": "^7.0.11",
    "fastify": "^4.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}

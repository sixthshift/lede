# Lede — environment. Copy to `.env` (gitignored) for local dev: `cp .env.example .env`
# then fill in real secrets. `bun run dev` / `bun start` load `.env` via `tsx --env-file`.

# ── Operator secrets (REQUIRED to boot — the server fail-fasts without them) ──
# Encrypts your stored provider API key (AES-256-GCM). 32 bytes, base64.
#   generate:  openssl rand -base64 32
# Keep this STABLE — if it changes, the stored provider key can no longer be decrypted.
LEDE_MASTER_KEY=

# Signs the login session cookie. At least 32 characters.
#   generate:  openssl rand -base64 48
LEDE_SESSION_SECRET=

# ── Optional ──
# fixture = keyless (replays recorded decisions; default under NODE_ENV=test);
# live = calls the real provider with your BYOK key. Use fixture for dev without a key.
LEDE_TAILOR_ENGINE=fixture

# HTTP port (default 8787 — matches the vite dev proxy in vite.config.ts).
PORT=8787

# Disable the auth gate for localhost/VPN-only use (default false). Does NOT bypass LEDE_MASTER_KEY.
# LEDE_AUTH_DISABLED=false

# SQLite data directory (default ./data).
# DATA_DIR=./data
